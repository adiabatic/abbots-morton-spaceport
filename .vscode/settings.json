{
  "editor.fontFamily": "'Abbots Morton Spaceport Mono', 'Departure Mono', monospace",
  "editor.fontSize": 16.5, // 11, 16.5, 22,
  "workbench.fontAliasing": "none",
  "terminal.integrated.fontSize": 11,

  "[html]": { "editor.wordBasedSuggestions": "off" },
  "tinymist.fontPaths": ["${workspaceFolder}/test"],

  "yaml.maxItemsComputed": 6000,
  "yaml.schemas": {
    "./.vscode/quikscript.schema.json": ["glyph_data/quikscript.yaml"],
    "./.vscode/permissive.schema.json": ["glyph_data/metadata.yaml"]
  },

  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["test", "-v"]
}
